/* pages/my/my.wxss */
.my_info_location image {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  left: -2rpx;
  top: 0rpx;
}

.my_info_username image {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  margin-left: 6rpx;

}

.my_info_username input {
  width: auto;
  max-width: 260rpx;
  height: 44rpx;
  line-height: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.login {
  padding: 0;
  overflow: hidden;
  background-image: none;
  background-color: transparent;
}

.login::after {
  border: none;
}

.login image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.my_edit_background {
  position: absolute;
  right: 6rpx;
  top: 2rpx;
  width: 64rpx;
  height: 52rpx;
  z-index: 999;
}

.my_info_setline {
  position: relative;
  max-width: 630rpx;
  min-width: 154rpx;
  width: auto;
  height: 100%;
  line-height: 34rpx;
}

.my_info_setline text {
  width: auto;
  opacity: 0;
  z-index: -1;
}

.my_info_setline textarea {
  position: absolute;
  left: 2px;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 108rpx;
  padding: 0!important;
  margin: 0!important;
}

.my_wrap {
  width: 100%;
  box-sizing: border-box;
  padding: 0 10rpx;
}

.diary-closed .my_header {
  height: 310rpx;
}

.diary-closed .my_info_top {
  top: 12%;
}

.diary-closed .my_container {
  top: 310rpx;
}
