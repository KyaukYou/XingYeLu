/* pages/myQuestion/myQuestion.wxss */
.my_container {
  top: 0rpx;
  bottom: 120rpx;
}

.add_question_btn {
  position: absolute;
  bottom: 16rpx;
  left: 4%;
  right: 4%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  border-radius: 10rpx;
}

.myList {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
}

.myList-container {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  overflow-y: scroll;
}

.myList-list {
  width: 100%;
  height: auto;
  padding-top: 10rpx;
  padding-bottom: 10rpx;
}

.myList-child {
  width: 96%;
  height: 110rpx;
  position: relative;
  background-color: rgb(242, 242, 242);
  margin: 20rpx auto 20rpx auto;
  border-radius: 8rpx;
}

.myList-left {
  position: absolute;
  top: 0;
  height: 100%;
  left: 0;
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.myList-left .myList-left-yes {
  font-size: 20rpx;
  display: inline-block;
  background-color: rgb(83, 216, 83);
  color: white;
  padding: 6rpx 6rpx;
  border-radius: 8rpx;
}

.myList-left .myList-left-no {
  font-size: 20rpx;
  display: inline-block;
  background-color: rgb(250, 69, 69);
  color: white;
  padding: 6rpx 6rpx;
  border-radius: 8rpx;
}

.myList-top {
  position: absolute;
  left: 120rpx;
  top: 4rpx;
  right: 0;
  height: 52rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  box-sizing: border-box;
  padding: 0 16rpx 0 4rpx;
}

.myList-top text {
  width: 100%;
  height: 52rpx;
  line-height: 52rpx;
  display: inline-block;
  overflow: hidden;
  text-overflow:ellipsis;
  white-space: nowrap;
  position: relative;
  top: 6rpx;
}

.myList-bottom {
  position: absolute;
  left: 120rpx;
  bottom: 0;
  right: 0;
  height: 50%;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: rgb(88, 88, 88);
}

.question_delete {
  position: absolute;
  right: 0;
  top: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  flex-flow: row nowrap;
  align-items: center;
  justify-content: center;
  z-index: 99;
  opacity: 0.7;
}

.my {
  background-color: #f6f8fb;
  z-index: 600;
}

.my_wrap {
  box-sizing: border-box;
  padding: 18rpx 24rpx 0;
}

.myList-child {
  width: 100%;
  min-height: 150rpx;
  height: auto;
  box-sizing: border-box;
  padding: 24rpx 24rpx 22rpx 132rpx;
  background-color: #fff;
  margin: 0 auto 22rpx;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(30, 45, 70, 0.08);
  overflow: hidden;
}

.myList-left {
  top: 24rpx;
  left: 22rpx;
  width: 92rpx;
  height: 42rpx;
}

.myList-left .myList-left-yes,
.myList-left .myList-left-no {
  min-width: 76rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.myList-left .myList-left-yes {
  background-color: #e9f8ef;
  color: #18a058;
}

.myList-left .myList-left-no {
  background-color: #fff1f0;
  color: #f04438;
}

.myList-top {
  position: static;
  height: auto;
  padding: 0 32rpx 0 0;
  font-size: 29rpx;
  color: #202733;
  line-height: 42rpx;
}

.myList-top text {
  height: auto;
  line-height: 42rpx;
  top: 0;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.myList-bottom {
  position: static;
  height: auto;
  margin-top: 16rpx;
  font-size: 23rpx;
  color: #8a94a6;
}

.question_delete {
  right: 12rpx;
  top: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: #f4f7fb;
}

.add_question_btn {
  bottom: 24rpx;
  left: 5%;
  right: 5%;
  height: 86rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 24rpx rgba(52, 132, 255, 0.22);
}
