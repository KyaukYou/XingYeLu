.my {
  min-height: 100vh;
  background: #f7f8fb;
  z-index: 600;
}

.header-color-bg {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 650;
  background-repeat: repeat;
}

.my_container {
  top: 0;
  height: 100vh;
  box-sizing: border-box;
}

.diary_loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 36rpx;
}

.my_wrap {
  position: relative;
  padding: 26rpx 34rpx 80rpx 34rpx;
  box-sizing: border-box;
}

.summary-card {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  margin: 0 0 28rpx 0;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #fff;
  box-shadow: 0 16rpx 40rpx rgba(40, 48, 68, 0.08);
}

.summary-icon {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  font-size: 34rpx;
  margin-right: 18rpx;
}

.summary-main {
  min-width: 0;
  flex: 1;
}

.summary-label {
  color: #8a90a0;
  font-size: 24rpx;
  line-height: 34rpx;
}

.summary-time {
  color: #232733;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
}

.up-cell {
  position: relative;
  width: 100%;
  margin: 0 0 28rpx 0;
  padding: 24rpx 24rpx 22rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #fff;
  color: #252936;
  box-shadow: 0 14rpx 34rpx rgba(39, 48, 73, 0.08);
}

.current {
  box-shadow: 0 18rpx 44rpx rgba(39, 48, 73, 0.12);
}

.version_top_borderX {
  position: absolute;
  left: -42rpx;
  top: 40rpx;
  bottom: -48rpx;
  width: 4rpx;
  border-radius: 99rpx;
  opacity: 0.28;
  display: none;
}

.version_top_circleX {
  position: absolute;
  left: -57rpx;
  top: 38rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(40, 48, 68, 0.16);
  display: none;
}

.version_top_circle_smX {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
}

.up-cell:last-child .version_top_borderX {
  display: none;
}

.ver {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.ver-badge {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
  margin-right: 16rpx;
  flex: none;
}

.ver-main {
  min-width: 0;
  flex: 1;
}

.ver-label {
  color: #8a90a0;
  font-size: 24rpx;
  line-height: 32rpx;
}

.ver-num {
  color: #1f2330;
  font-size: 36rpx;
  line-height: 46rpx;
  font-weight: 700;
}

.new_version {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(32, 38, 54, 0.08);
}

.new_version_title {
  display: flex;
  align-items: center;
  color: #303544;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.section-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex: none;
}

.new_version_info,
.up-show {
  width: 100%;
}

.new_version_info_list,
.up-show {
  display: flex;
  align-items: flex-start;
  min-height: 44rpx;
  margin-top: 8rpx;
}

.new_version_titleX {
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  margin: 5rpx 12rpx 0 0;
  border-radius: 50%;
  background: #f0f2f6;
  color: #747b8d;
  text-align: center;
  font-size: 22rpx;
  flex: none;
}

.new_itemX {
  flex: 1;
  min-width: 0;
  color: #4c5364;
  font-size: 28rpx;
  line-height: 44rpx;
  word-break: break-all;
}
