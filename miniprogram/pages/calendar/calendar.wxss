.record-page {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 600;
  background: #f6f8fb;
  box-sizing: border-box;
}

.calendar-fixed {
  position: absolute;
  top: 172rpx;
  left: 0;
  right: 0;
  box-sizing: border-box;
  padding: 28rpx 24rpx 0;
}

.record-scroll {
  position: absolute;
  top: 942rpx;
  left: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
  padding: 0 24rpx 12rpx;
}

.month-card,
.empty-card,
.record-card {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 28rpx rgba(30, 45, 70, 0.08);
}

.month-card {
  padding: 24rpx 22rpx 22rpx;
}

.month-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 62rpx;
}

.month-title {
  color: #202733;
  font-size: 34rpx;
  font-weight: 700;
}

.month-arrow {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5f6b7a;
  background: #f4f7fb;
  font-size: 48rpx;
  line-height: 60rpx;
}

.week-head,
.calendar-week {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-head {
  margin-top: 20rpx;
  color: #98a2b3;
  font-size: 24rpx;
  text-align: center;
}

.calendar-grid {
  margin-top: 10rpx;
}

.calendar-day {
  height: 88rpx;
  margin: 4rpx;
  border-radius: 18rpx;
  color: #344054;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  position: relative;
}

.calendar-day.is-today {
  background: #f2f4f7;
}

.calendar-day.is-selected {
  color: #fff;
  background: #4a90d9;
  box-shadow: 0 10rpx 24rpx rgba(74, 144, 217, 0.24);
}

.day-dots {
  position: absolute;
  bottom: 12rpx;
  display: flex;
  gap: 4rpx;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.more-dot {
  background: #d0d5dd;
}

.day-section {
  margin: 14rpx 4rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.day-title {
  color: #202733;
  font-size: 32rpx;
  font-weight: 700;
}

.day-sub {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.day-add {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #4a90d9;
  background: #eaf3ff;
  font-size: 24rpx;
}

.empty-state {
  width: 100%;
  min-height: 96rpx;
  padding: 40rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.empty-card {
  padding: 48rpx 34rpx;
  text-align: center;
}

.empty-title {
  color: #202733;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #8a94a6;
  font-size: 26rpx;
  line-height: 40rpx;
}

.empty-action {
  width: 240rpx;
  height: 76rpx;
  margin: 32rpx auto 0;
  border-radius: 18rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.record-card {
  margin-bottom: 22rpx;
  display: flex;
  overflow: hidden;
}

.record-line {
  width: 8rpx;
}

.record-main {
  flex: 1;
  min-width: 0;
  padding: 24rpx 26rpx 22rpx;
}

.record-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #8a94a6;
  font-size: 23rpx;
}

.record-title {
  margin-top: 10rpx;
  color: #202733;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.record-preview {
  margin-top: 8rpx;
  color: #5f6b7a;
  font-size: 26rpx;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.record-tags text {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #667085;
  background: #f2f4f7;
  font-size: 22rpx;
}

.record-fab {
  position: fixed;
  right: 8%;
  bottom: 8%;
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  color: #fff;
  z-index: 999;
  font-size: 72rpx;
  line-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(52, 132, 255, 0.28);
}
