<lc_header header_title="记录详情" header_color="{{globalData.color || '#4a90d9'}}" blur="{{globalData.blur}}" back="{{back}}"></lc_header>
<l-toast show="{{toastBol}}" title="{{toastTitle}}" duration="{{toastDuration}}" />

<view class="record-page" style="padding-top: {{globalData.customHeight.height + globalData.customHeight.top + 6}}px;">
  <scroll-view class="detail-scroll" scroll-y>
    <view class="hero-card">
      <view class="record-type">{{record.typeText}}</view>
      <view class="record-title">{{record.displayTitle}}</view>
      <view class="record-date">{{record.event_date}}</view>
      <view class="record-level">{{record.importanceText}}</view>
    </view>

    <view class="content-card">
      <view class="section-title">内容</view>
      <view class="description">{{record.description || '没有填写内容'}}</view>
      <view class="meta-row" wx:if="{{record.mood || record.location}}">
        <text wx:if="{{record.mood}}">{{record.mood}}</text>
        <text wx:if="{{record.location}}">{{record.location}}</text>
      </view>
      <view class="tags" wx:if="{{record.tags.length}}">
        <text wx:for="{{record.tags}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <view class="image-grid" wx:if="{{record.images.length}}">
      <image wx:for="{{record.images}}" wx:key="index" wx:for-index="image_index" data-index="{{image_index}}" bindtap="previewImage" src="{{item.url}}" mode="aspectFill"></image>
    </view>

    <view class="actions">
      <view class="action ghost" bindtap="deleteRecord">删除</view>
      <view class="action primary" style="background: {{globalData.color || '#4a90d9'}}" bindtap="toEdit">编辑</view>
    </view>
  </scroll-view>
</view>
