<lc_header header_title="日志管理" header_color="{{globalData.color}}" blur="{{globalData.blur}}" back="{{back}}"></lc_header>
<view class="header-color-bg"
  style="height: {{globalData.customHeight.height+globalData.customHeight.top+12}}px; background-color: {{globalData.color}}; background-image: {{globalData.blur === true ? 'url(https://6c69-littlechai-8gbpxj2baa4e412f-1257711591.tcb.qcloud.la/system/dot.png?sign=f6f105901602fb46727be2f82c1b33b4&t=1610067412)' : ''}};">
</view>

<l-toast show="{{toastBol}}" icon="loading" title="{{toastTitle}}" duration="{{toastDuration}}" />
<l-toast show="{{toastBol1}}" icon="{{updateIcon}}" title="{{toastTitle1}}" duration="{{toastDuration1}}" />

<view class="my" style="padding-top: {{globalData.customHeight.height+globalData.customHeight.top+12}}px;">
  <scroll-view wx:if="{{verBol === true}}" style="padding-top: {{globalData.customHeight.height+globalData.customHeight.top+12}}px;"
    class="my_container" scroll-y refresher-enabled bindrefresherrefresh="refresh" refresher-triggered="{{refreshBol}}" bindscrolltolower="scrollToBottom">
    <view class="my_wrap">
      <view class="editVersion_long">
        <view class="editVersion_color ghost-btn" style="color: {{globalData.color}}; border-color: {{globalData.color}};" bindtap="createVersion">
          <text class="btn-icon">+</text>
          <text>新增版本</text>
        </view>
        <view class="editVersion_color primary-btn" style="background-color: {{globalData.color}}" bindtap="updateVersion">
          <text class="btn-icon">✓</text>
          <text>提交更新</text>
        </view>
      </view>

      <view class="{{index == 0 ? 'current up-cell' : 'up-cell'}}" wx:for="{{verData}}" wx:key="index">
        <view class="version_top_borderX" style="background-color: {{globalData.color}}"></view>
        <view class="version_top_circleX" style="border-color: {{globalData.color}}">
          <view class="version_top_circle_smX" style="background-color: {{globalData.color}};"></view>
        </view>

        <block wx:if="{{item.type === 'new'}}">
          <view class="ver">
            <view class="ver-badge" style="background-color: {{globalData.color}};">{{index == 0 ? "✓" : "•"}}</view>
            <view class="ver-main">
              <view class="ver-label">{{index == 0 ? "当前版本" : "历史版本"}}</view>
              <input bindinput="changeVer" data-index="{{index}}" type="text" value="{{item.text}}" class="editVersion_input" placeholder="请输入版本号" />
            </view>
            <view data-index1="{{index}}" class="icon-btn danger" bindtap="delOne">×</view>
          </view>

          <view class="new_version" wx:for="{{item.arr}}" wx:key="index" wx:for-item="new_item" wx:for-index="new_index">
            <view class="new_version_title">
              <view class="section-dot" style="background-color: {{globalData.color}};"></view>
              <input bindinput="changeTitle" data-index1="{{index}}" data-index2="{{new_index}}" placeholder="请输入分类标题" type="text" value="{{new_item.title}}" />
              <view class="icon-btn add" data-index1="{{index}}" data-index2="{{new_index}}" bindtap="addTitle">+</view>
              <view class="icon-btn danger" data-index1="{{index}}" data-index2="{{new_index}}" bindtap="delTwo">×</view>
            </view>

            <view class="new_version_info">
              <view class="new_version_info_list" wx:for="{{new_item.info}}" wx:key="new_item_index" wx:for-item="new_item_list" wx:for-index="new_item_index">
                <view class="new_version_titleX">{{new_item_index+1}}</view>
                <view class="new_itemX">
                  <input placeholder="请输入日志内容" bindinput="changeInfo" data-index1="{{index}}" data-index2="{{new_index}}" data-index3="{{new_item_index}}" type="text" value="{{new_item_list}}" />
                  <view class="icon-btn add" data-index1="{{index}}" data-index2="{{new_index}}" data-index3="{{new_item_index}}" bindtap="addInfo">+</view>
                  <view class="icon-btn danger" data-index1="{{index}}" data-index2="{{new_index}}" data-index3="{{new_item_index}}" bindtap="delThree">×</view>
                </view>
              </view>
            </view>
          </view>
        </block>

        <block wx:if="{{item.type === 'old'}}">
          <view class="ver">
            <view class="ver-badge" style="background-color: {{globalData.color}};">{{index == 0 ? "✓" : "•"}}</view>
            <view class="ver-main">
              <view class="ver-label">{{index == 0 ? "当前版本" : "历史版本"}}</view>
              <view class="ver-num">{{item.text}}</view>
            </view>
          </view>
          <view class="up-show" wx:for="{{item.arr}}" wx:key="index" wx:for-item="tItem">
            <view class="new_version_titleX">{{index+1}}</view>
            <view class="new_itemX">{{tItem}}</view>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>
</view>
