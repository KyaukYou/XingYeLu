/* pages/uploadQuestion/uploadQuestion.wxss */
.my_container {
  top: 0rpx;
  bottom: 120rpx;
}

.add_question_btn {
  position: absolute;
  bottom: 16rpx;
  left: 4%;
  right: 4%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  border-radius: 10rpx;
}

textarea {
  width: 100%;
  height: 500rpx;
  /* border-bottom: 2rpx solid rgb(252, 252, 252); */
  box-shadow:0 0 8rpx rgb(210,210,210);
  font-size: 28rpx;
  box-sizing: border-box;
  padding: 20rpx;
  position: relative;
  margin: 0rpx auto 0 auto;
  border-radius: 10rpx;
}

textarea view {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  font-size: 26rpx;
  color: rgb(221,221,221);
}

button {
  position: absolute;
  bottom: 20rpx;
  left: 2%;
  width: 96%;
  right: 2%;
  background-color: #f47695;
  color: white;
}

.my {
  background-color: #f6f8fb;
  z-index: 600;
}

.my_wrap {
  box-sizing: border-box;
  padding: 22rpx 24rpx 0;
}

textarea {
  width: 100%;
  height: 520rpx;
  margin: 0 auto;
  padding: 28rpx 28rpx 62rpx;
  background-color: #fff;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 28rpx rgba(30, 45, 70, 0.08);
  font-size: 29rpx;
  line-height: 44rpx;
  color: #202733;
}

textarea view {
  right: 28rpx;
  bottom: 20rpx;
  font-size: 23rpx;
  color: #a7b0bf;
}

.add_question_btn {
  bottom: 24rpx;
  left: 5%;
  right: 5%;
  height: 86rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 24rpx rgba(52, 132, 255, 0.22);
}
